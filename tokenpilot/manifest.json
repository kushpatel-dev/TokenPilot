{
  "manifest_version": 3,
  "name": "TokenPilot",
  "version": "3.5",
  "description": "Real-time token counter, prompt analysis & history for ChatGPT, Claude, Gemini and more.",
  "permissions": ["storage", "tabs", "scripting", "alarms", "clipboardRead"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://mistral.ai/*",
    "https://chat.mistral.ai/*",
    "https://deepseek.com/*",
    "https://chat.deepseek.com/*",
    "https://github.com/*",
    "https://arena.ai/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://mistral.ai/*",
        "https://chat.mistral.ai/*",
        "https://deepseek.com/*",
        "https://chat.deepseek.com/*",
        "https://github.com/*",
        "https://arena.ai/*"
      ],
      "js": ["vendor/gpt-tokenizer-cl100k.js", "data/models.js", "data/modelRegistry.js", "utils/tokenCounter.js", "content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://mistral.ai/*",
        "https://chat.mistral.ai/*",
        "https://deepseek.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content/autopaste.js", "content/relayImporter.js"],
      "run_at": "document_idle"
    }
  ]
}