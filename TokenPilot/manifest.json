{
  "manifest_version": 3,
  "name": "TokenPilot",
  "version": "3.0",
  "description": "Premium token counter and prompt history for all AI tools",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
